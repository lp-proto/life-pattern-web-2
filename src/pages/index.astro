---
import FeatureRow from "../components/FeatureRow.astro";
import Layout from "../components/Layout.astro";
import StoreButtons from "../components/StoreButtons.astro";
import { howItWorks } from "../site/content";
---

<Layout activePage="home">
	<main>
		<section class="hero-band">
			<div class="section hero-grid">
				<div class="hero-copy">
					<h1>Plan, journal, and understand your life with AI</h1>
					<p>Plan personal journeys to achieve goals or manage conditions with help from AI.</p>
					<p>Journal your conditions and experiences in your own words, then discover subtle rhythms and habits in your daily life.</p>
					<p>Understand triggers and patterns so you can manage stress, adopt positive routines, and stay on top of your journeys.</p>
					<StoreButtons />
				</div>
				<div class="hero-media">
					<img src="/assets/images/hero3.svg" alt="LifePattern AI journal and insights illustration" />
				</div>
			</div>
			<div class="section practitioner-strip">
				<p>For healthcare practitioners, therapists and coaches, learn how LifePattern AI can help clients document their patterns and conditions, obtain useful data, and improve treatment adherence.</p>
				<a class="button button-small" href="/practitioners">Learn More</a>
			</div>
		</section>

		<section class="section">
			<div class="section-heading">
				<h2>How LifePattern AI Works</h2>
				<p>Journal in your own words, and let LifePattern AI do the rest.</p>
			</div>
			{howItWorks.map((feature) => <FeatureRow {...feature} />)}
		</section>
	</main>
</Layout>
