---
import Logo from "./Logo.astro";

interface Props {
	activePage?: "home" | "features" | "practitioners";
	blank?: boolean;
}

const { activePage, blank = false } = Astro.props;
---

<header class="site-header" data-site-header>
	<div class="section nav-section">
		<a href="/" class="brand-link" aria-label="LifePattern AI home">
			<Logo size="large" />
		</a>
		<nav class="main-nav" aria-label="Main navigation">
			<a class:list={{ active: activePage === "home" }} href="/">Home</a>
			{!blank && (
				<>
					<a class:list={{ active: activePage === "features" }} href="/features">Features</a>
					<a class:list={{ active: activePage === "practitioners" }} href="/practitioners">Practitioners</a>
					<a class="button button-small" href="/beta">Get the beta now</a>
				</>
			)}
		</nav>
	</div>
</header>
