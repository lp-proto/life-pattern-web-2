---
interface Props {
	title: string;
	description: string;
	image: string;
	imageAlt: string;
	reverse?: boolean;
}

const { title, description, image, imageAlt, reverse = false } = Astro.props;
---

<div class:list={["feature-row", { "feature-row-reverse": reverse }]}>
	<div class="feature-copy">
		<h3>{title}</h3>
		<p>{description}</p>
	</div>
	<div class="feature-media">
		<img src={image} alt={imageAlt} loading="lazy" />
	</div>
</div>
